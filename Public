<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Daytime Sessions — Venue Finder</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap');

  :root{
    --paper:#F2EFE6;
    --ink:#1B1B18;
    --marker:#E8A33D;
    --stamp:#B5432A;
    --card:#FFFFFF;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:var(--paper);
    background-image: radial-gradient(circle at 1px 1px, rgba(27,27,24,0.06) 1px, transparent 0);
    background-size: 18px 18px;
    color:var(--ink);
    font-family:'Space Mono', monospace;
    min-height:100vh;
  }
  .wrap{ max-width:640px; margin:0 auto; padding:28px 20px 60px; }
  header{ border-bottom:3px solid var(--ink); padding-bottom:16px; margin-bottom:24px; }
  .eyebrow{ font-size:11px; letter-spacing:0.14em; text-transform:uppercase; display:flex; justify-content:space-between; margin-bottom:10px; }
  h1{ font-family:'Archivo Black', sans-serif; font-size:clamp(30px, 8vw, 44px); line-height:0.95; margin:0 0 6px; text-transform:uppercase; letter-spacing:-0.01em; }
  .sub{ font-size:13px; max-width:46ch; opacity:0.75; }
  form{ display:flex; gap:8px; margin:22px 0 8px; }
  input[type="text"]{ flex:1; font-family:'Space Mono', monospace; font-size:15px; padding:14px 12px; border:2px solid var(--ink); background:var(--card); color:var(--ink); border-radius:0; }
  input[type="text"]:focus{ outline:3px solid var(--marker); outline-offset:1px; }
  button{ font-family:'Archivo Black', sans-serif; font-size:13px; text-transform:uppercase; letter-spacing:0.04em; background:var(--ink); color:var(--paper); border:2px solid var(--ink); padding:0 20px; cursor:pointer; }
  button:hover{ background:var(--stamp); border-color:var(--stamp); }
  button:disabled{ opacity:0.5; cursor:wait; }
  .hint{ font-size:11px; opacity:0.6; margin-bottom:30px; }
  #status{ font-size:13px; margin:18px 0; display:none; }
  #status.show{ display:block; }
  .pulse{ display:inline-block; width:8px; height:8px; background:var(--stamp); border-radius:50%; margin-right:8px; animation:pulse 1s infinite ease-in-out; }
  @keyframes pulse{ 50%{ opacity:0.2; } }
  #results{ display:flex; flex-direction:column; gap:14px; }
  .card{ background:var(--card); border:2px solid var(--ink); padding:16px 18px; position:relative; box-shadow:5px 5px 0 rgba(27,27,24,0.9); }
  .card .name{ font-family:'Archivo Black', sans-serif; font-size:18px; text-transform:uppercase; margin:0 0 6px; padding-right:90px; }
  .badge{ position:absolute; top:14px; right:14px; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; padding:4px 8px; border:2px solid var(--stamp); color:var(--stamp); transform:rotate(3deg); text-align:right; }
  .meta{ font-size:12.5px; line-height:1.6; opacity:0.85; }
  .meta b{ opacity:1; }
  .divider{ border:none; border-top:1px dashed rgba(27,27,24,0.35); margin:10px 0; }
  footer{ margin-top:40px; font-size:10.5px; opacity:0.55; border-top:1px solid rgba(27,27,24,0.25); padding-top:14px; }
  .empty{ font-size:13px; opacity:0.6; padding:20px 0; }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="eyebrow"><span>Vol. 01 — Local Listings</span><span id="today"></span></div>
    <h1>Daytime<br>Sessions</h1>
    <div class="sub">Small venues and cafés with live music you can actually catch on a working day.</div>
  </header>

  <form id="searchForm">
    <input type="text" id="location" placeholder="Neighborhood, city, or zip" autocomplete="off" required>
    <button type="submit" id="goBtn">Find</button>
  </form>
  <div class="hint">Try: "Camden, London" or "Portland, OR"</div>

  <div id="status"><span class="pulse"></span><span id="statusText">Scouting the area…</span></div>
  <div id="results"></div>

  <footer>Listings pulled live via web search — always confirm hours directly before heading out.</footer>
</div>

<script>
document.getElementById('today').textContent = new Date().toLocaleDateString('en-US', { weekday:'long', month:'short', day:'numeric' });

const form = document.getElementById('searchForm');
const btn = document.getElementById('goBtn');
const status = document.getElementById('status');
const statusText = document.getElementById('statusText');
const results = document.getElementById('results');

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  const location = document.getElementById('location').value.trim();
  if(!location) return;

  btn.disabled = true;
  status.classList.add('show');
  statusText.textContent = 'Scouting ' + location + '…';
  results.innerHTML = '';

  try{
    // Calls YOUR OWN backend (server.js) instead of Claude's artifact API.
    // The backend holds the Anthropic API key privately.
    const response = await fetch('/api/search', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ location })
    });

    if(!response.ok){
      const errData = await response.json().catch(() => ({}));
      throw new Error(errData.error || 'Search failed');
    }

    const { venues } = await response.json();
    status.classList.remove('show');

    if(!venues || venues.length === 0){
      results.innerHTML = '<div class="empty">No listings turned up for that area. Try a nearby town or the closest bigger city.</div>';
    } else {
      results.innerHTML = venues.map(v => `
        <div class="card">
          <span class="badge">${escapeHtml(v.type || 'Listing')}</span>
          <div class="name">${escapeHtml(v.name || 'Unnamed venue')}</div>
          <div class="meta"><b>Hours:</b> ${escapeHtml(v.hours || 'Not listed')}</div>
          <hr class="divider">
          <div class="meta">${escapeHtml(v.note || '')}</div>
        </div>
      `).join('');
    }
  }catch(err){
    status.classList.remove('show');
    results.innerHTML = '<div class="empty">Something went wrong: ' + escapeHtml(err.message) + '. Give it another try.</div>';
  }finally{
    btn.disabled = false;
  }
});

function escapeHtml(str){
  const div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}
</script>
</body>
</html>
